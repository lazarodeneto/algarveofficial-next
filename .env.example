NEXT_PUBLIC_SITE_URL=https://algarveofficial.com
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SUPABASE_PROJECT_ID=
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Google Analytics Data API (server-side for /admin/analytics real GA4 data)
# Set at least GA_PROPERTY_ID + one service-account credential option below.
GA_PROPERTY_ID=
# Option A: full service account JSON as a single env var
GA_SERVICE_ACCOUNT_JSON=
# Option B: split service account credentials
GA_SERVICE_ACCOUNT_EMAIL=
GA_SERVICE_ACCOUNT_PRIVATE_KEY=
# Server-only (not exposed to browser)
SUPABASE_SERVICE_ROLE_KEY=

# Server-only operational secrets
# Vercel Cron sends Authorization: Bearer $CRON_SECRET to /api/translate.
CRON_SECRET=
# Required by /api/revalidate for manual/on-demand CMS cache revalidation.
REVALIDATE_SECRET=
# Used by Admin CMS preview URL generation and /api/preview.
PREVIEW_SECRET=
# Server-only WeatherAPI.com key for /api/weather. Do not expose this to the browser.
WEATHERAPI_KEY=

# Stripe server-only configuration
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Resend/email server-only configuration
RESEND_API_KEY=
RESEND_FROM_EMAIL=
RESEND_FROM_NAME=
RESEND_REPLY_TO_EMAIL=
RESEND_AUDIENCE_ID=
RESEND_NEWSLETTER_SEGMENT_ID=
RESEND_NEWSLETTER_TOPIC_ID=
RESEND_WEBHOOK_SECRET=
NEWSLETTER_TOKEN_SECRET=
ADMIN_NOTIFICATION_EMAILS=
CONTACT_NOTIFICATION_EMAIL=
CLAIM_NOTIFICATION_EMAIL=

# Transitional aliases for current legacy email code. Prefer RESEND_* names in new code.
EMAIL_FROM=
EMAIL_REPLY_TO=
RESEND_TRANSACTIONAL_FROM=

# Sentry production error monitoring
# NEXT_PUBLIC_SENTRY_DSN is intentionally public; keep SENTRY_DSN/SENTRY_AUTH_TOKEN server-only.
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
