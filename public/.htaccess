# SPA Routing - Redirect all non-file/directory requests to index.html
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /
  
  # Ensure HTTPS
  RewriteCond %{HTTPS} off
  RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

  # Redirect legacy non-www or other domain aliases safely if needed
  # RewriteCond %{HTTP_HOST} !^algarveofficial\.com$ [NC]
  # RewriteRule ^(.*)$ https://algarveofficial.com/$1 [L,R=301]

  RewriteRule ^index\.html$ - [L]
  # Force SPA shell for known app routes, even if stale directories exist on host.
  RewriteRule ^(?:(pt-pt|fr|de|es|it|nl|sv|no|da)/)?(live|invest|trips|destinations|city|listing|directory|map|blog|events|about-us|about|partner|contact|real-estate|privacy-policy|terms|cookie-policy|login|signup|forgot-password|auth|admin|owner|dashboard)(/.*)?$ /index.html [L,E=SPA_HTML:1]
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  # Flag SPA route rewrites so we can force no-cache headers on all app routes
  RewriteRule . /index.html [L,E=SPA_HTML:1]
  
  # Prevent caching of the main HTML file to ensure updates are seen immediately
  <Files "index.html">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
    Header set Pragma "no-cache"
    Header set Expires "0"
  </Files>
</IfModule>

# Security Headers & CORS
<IfModule mod_headers.c>
  # Ensure all SPA HTML responses (/, /live, /invest, etc.) are never cached.
  Header always set Cache-Control "no-cache, no-store, must-revalidate, max-age=0" env=SPA_HTML
  Header always set Pragma "no-cache" env=SPA_HTML
  Header always set Expires "0" env=SPA_HTML
  Header always set CDN-Cache-Control "no-store" env=SPA_HTML
  Header always set Surrogate-Control "no-store" env=SPA_HTML
  Header always set Strict-Transport-Security "max-age=63072000; includeSubDomains; preload"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set Permissions-Policy "camera=(), microphone=(), geolocation=(self)"

  Header set X-Content-Type-Options "nosniff"
  Header set X-Frame-Options "SAMEORIGIN"
  Header set X-XSS-Protection "1; mode=block"
  
  # Enable CORS for all assets and domains (essential for .com vs .pt setup)
  <FilesMatch "\.(js|css|woff|woff2|ttf|eot|svg|png|jpg|jpeg|webp|gif|ico|ttc|otf|font.css|json)$">
    Header set Access-Control-Allow-Origin "*"
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>

  # Sitemap and robots must refresh quickly for search engines
  <FilesMatch "^(sitemap\.xml|robots\.txt)$">
    Header set Cache-Control "no-cache, no-store, must-revalidate, max-age=0"
    Header set Pragma "no-cache"
    Header set Expires "0"
    Header set CDN-Cache-Control "no-store"
    Header set Surrogate-Control "no-store"
  </FilesMatch>

  # Content Security Policy - Permissive for analytic tools and Supabase
  # Added *.google.pt, *.google.com, and stats.g.doubleclick.net
  Header set Content-Security-Policy "default-src 'self'; script-src 'self' https://www.googletagmanager.com https://www.google-analytics.com https://*.google.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com data:; img-src 'self' data: https: blob:; connect-src 'self' https://*.supabase.co https://www.google-analytics.com https://*.analytics.google.com https://www.googletagmanager.com https://stats.g.doubleclick.net https://*.google.pt https://*.google.com; frame-src 'self' https://www.youtube.com; media-src 'self' https://*.supabase.co; object-src 'none'; base-uri 'self'; form-action 'self'; upgrade-insecure-requests;"
</IfModule>

# Compression
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/plain text/html text/xml text/css application/xml application/xhtml+xml application/rss+xml application/javascript application/x-javascript application/json
</IfModule>

# Caching for Static Assets (1 year)
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresDefault "access plus 1 month"
  ExpiresByType image/x-icon "access plus 1 year"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/gif "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType text/css "access plus 1 year"
  ExpiresByType text/javascript "access plus 1 year"
  ExpiresByType application/javascript "access plus 1 year"
  ExpiresByType application/x-javascript "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType application/font-woff "access plus 1 year"
  ExpiresByType application/font-woff2 "access plus 1 year"
</IfModule>
